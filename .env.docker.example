APP_NAME=Dog Breed Recognition TP2
# Modelo usado para generar embeddings en la busqueda por similitud:
# baseline (pre-entrenado ImageNet) | resnet18_finetuned | cnn_custom
EMBEDDING_MODEL=baseline
MODEL_PATH=models
RESNET18_MODEL_NAME=resnet18_finetuned.pth
CNN_CUSTOM_MODEL_NAME=cnn_custom.pth

# Busqueda por similitud
SIMILARITY_METRIC=cosine
SIMILARITY_THRESHOLD=0.55
# Cantidad de vecinos a recuperar (Top K)
TOP_K=10
IMAGE_SIZE=224
# Debe coincidir con la dimension del embedding del modelo elegido (ResNet50 GAP = 2048, ResNet18 = 512)
EMBEDDING_DIM=2048

# Configuracion de YOLO (Etapa 3)
YOLO_MODEL=yolov8n.pt
YOLO_CONF_THRESHOLD=0.25
# Clase 'dog' en COCO
YOLO_DOG_CLASS_ID=16

# Paths
EMBEDDINGS_PATH=data/embeddings.json
DATA_PATH=data
DATASET_PATH=data/dataset
OUTPUT_PATH=output
CORS_ORIGINS="http://localhost:8080,http://frontend:8080"
MAX_WORKERS=2

# PostgreSQL / pgvector
USE_PGVECTOR=true
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dogs
POSTGRES_USER=dogs_user
POSTGRES_PASSWORD=dogs_pass
